@echo off
title AYDA Musavirlik - Tam Sistem
color 0E

echo.
echo  ?????????????????????????????????????????????????????????????
echo  ?                                                           ?
echo  ?              AYDA MUSAVIRLIK SISTEMI                      ?
echo  ?                  TAM KURULUM                              ?
echo  ?                                                           ?
echo  ?????????????????????????????????????????????????????????????
echo.

echo [1/5] Projeler derleniyor...
dotnet build AydaMusavirlik.sln -c Release --verbosity quiet
if errorlevel 1 (
    echo HATA: Derleme basarisiz!
    pause
    exit /b 1
)
echo      Derleme tamamlandi.

echo.
echo [2/5] API servisi baslatiliyor (Port: 5000)...
start "AYDA API" /MIN cmd /c "cd /d %~dp0AydaMusavirlik.Api && dotnet run -c Release --urls=http://localhost:5000"

timeout /t 4 /nobreak > nul

echo [3/5] Web uygulamasi baslatiliyor (Port: 5001)...
start "AYDA Web" /MIN cmd /c "cd /d %~dp0AydaMusavirlik.Web && dotnet run -c Release --urls=http://localhost:5001"

timeout /t 3 /nobreak > nul

echo [4/5] Desktop uygulamasi baslatiliyor...
start "AYDA Desktop" cmd /c "cd /d %~dp0AydaMusavirlik.Desktop && dotnet run -c Release"

timeout /t 2 /nobreak > nul

echo [5/5] Web tarayicisi aciliyor...
start http://localhost:5001

echo.
echo  ?????????????????????????????????????????????????????????????
echo  ?                                                           ?
echo  ?  TUM UYGULAMALAR BASLATILDI!                              ?
echo  ?                                                           ?
echo  ?  Web:     http://localhost:5001                           ?
echo  ?  API:     http://localhost:5000                           ?
echo  ?  Desktop: Ayri pencerede acildi                           ?
echo  ?                                                           ?
echo  ?  Giris Bilgileri:                                         ?
echo  ?  Kullanici: admin                                         ?
echo  ?  Sifre:     admin123                                      ?
echo  ?                                                           ?
echo  ?????????????????????????????????????????????????????????????
echo.

pause
