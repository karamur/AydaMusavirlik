<UserControl x:Class="AydaMusavirlik.Desktop.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Mali Dashboard" FontSize="24" FontWeight="Bold" 
                       Foreground="White" Margin="0,0,0,20"/>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                <Border Background="#2D5A27" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Toplam Gelir" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtToplamGelir" Text="1.250.000 TL" Foreground="White" 
                                   FontSize="22" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="+%12.5 gecen aya gore" Foreground="#90EE90" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#8B0000" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Toplam Gider" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtToplamGider" Text="980.000 TL" Foreground="White" 
                                   FontSize="22" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="-%3.2 gecen aya gore" Foreground="#FFB6C1" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E3A5F" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Net Kar" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtNetKar" Text="270.000 TL" Foreground="White" 
                                   FontSize="22" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="Kar Marji: %21.6" Foreground="LightGray" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#4A4A4A" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Mali Saglik" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtMaliSaglik" Text="78/100" Foreground="White" 
                                   FontSize="22" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="B+ Seviyesi" Foreground="LightGray" FontSize="10"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Mali Oranlar" Foreground="White" FontWeight="Bold" 
                                   FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cari Oran" Foreground="LightGray"/>
                            <TextBlock Grid.Column="1" Text="1.85" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Asit Test Orani" Foreground="LightGray"/>
                            <TextBlock Grid.Column="1" Text="1.42" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Borc/Ozkaynak" Foreground="LightGray"/>
                            <TextBlock Grid.Column="1" Text="0.65" Foreground="Yellow" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Net Kar Marji" Foreground="LightGray"/>
                            <TextBlock Grid.Column="1" Text="%21.6" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ROE" Foreground="LightGray"/>
                            <TextBlock Grid.Column="1" Text="%18.5" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Son Islemler" Foreground="White" FontWeight="Bold" 
                                   FontSize="14" Margin="0,0,0,15"/>
                        
                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8" Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Satis Geliri - ABC Ltd." Foreground="White" FontSize="11"/>
                                    <TextBlock Text="Bugun 14:30" Foreground="Gray" FontSize="9"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="+45.000 TL" Foreground="LightGreen" 
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8" Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Personel Maaslari" Foreground="White" FontSize="11"/>
                                    <TextBlock Text="Bugun 10:00" Foreground="Gray" FontSize="9"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="-125.000 TL" Foreground="LightCoral" 
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8" Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Hizmet Geliri - XYZ A.S." Foreground="White" FontSize="11"/>
                                    <TextBlock Text="Dun 16:45" Foreground="Gray" FontSize="9"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="+28.500 TL" Foreground="LightGreen" 
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8" Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Kira Odemesi" Foreground="White" FontSize="11"/>
                                    <TextBlock Text="Dun 09:00" Foreground="Gray" FontSize="9"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="-15.000 TL" Foreground="LightCoral" 
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Hizli Erisim" Foreground="White" FontWeight="Bold" 
                               FontSize="14" Margin="0,0,0,15"/>
                    <WrapPanel>
                        <Button Content="Firma Sec" Background="#007ACC" Foreground="White" 
                                Padding="15,8" Margin="5" Click="FirmaSec_Click"/>
                        <Button Content="Fis Girisi" Background="#4CAF50" Foreground="White" 
                                Padding="15,8" Margin="5" Click="FisGirisi_Click"/>
                        <Button Content="Bordro Hesapla" Background="#FF9800" Foreground="White" 
                                Padding="15,8" Margin="5" Click="BordroHesapla_Click"/>
                        <Button Content="Mizan" Background="#9C27B0" Foreground="White" 
                                Padding="15,8" Margin="5" Click="Mizan_Click"/>
                        <Button Content="Mali Analiz" Background="#E91E63" Foreground="White" 
                                Padding="15,8" Margin="5" Click="MaliAnaliz_Click"/>
                        <Button Content="PDF Rapor" Background="#795548" Foreground="White" 
                                Padding="15,8" Margin="5" Click="PdfRapor_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
