<UserControl x:Class="AydaMusavirlik.Desktop.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Baslik ve Tarih -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Mali Dashboard" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="txtTarih" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ComboBox x:Name="cmbDonem" Width="150" Margin="0,0,10,0"/>
                    <Button x:Name="btnYenile" Content="🔄 Yenile" Width="100" Height="32"
                            Background="{DynamicResource PrimaryBrush}" Foreground="White" Click="BtnYenile_Click"/>
                </StackPanel>
            </Grid>

            <!-- Ozet Kartlar -->
            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,20">
                <Border Background="#4CAF50" CornerRadius="8" Margin="5" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📈 Toplam Gelir" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtToplamGelir" Text="0 TL" Foreground="White" 
                                   FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtGelirDegisim" Text="+%0" Foreground="#C8E6C9" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#F44336" CornerRadius="8" Margin="5" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📉 Toplam Gider" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtToplamGider" Text="0 TL" Foreground="White" 
                                   FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtGiderDegisim" Text="+%0" Foreground="#FFCDD2" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#2196F3" CornerRadius="8" Margin="5" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="💰 Net Kar" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtNetKar" Text="0 TL" Foreground="White" 
                                   FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtKarMarji" Text="Kar Marji: %0" Foreground="#BBDEFB" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border Background="#9C27B0" CornerRadius="8" Margin="5" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="👥 Personel" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtPersonelSayisi" Text="0" Foreground="White" 
                                   FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtBordroToplam" Text="Bordro: 0 TL" Foreground="#E1BEE7" FontSize="10"/>
                    </StackPanel>
                </Border>

                <Border x:Name="brdMaliSaglik" Background="#607D8B" CornerRadius="8" Margin="5" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="❤️ Mali Saglik" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="txtMaliSaglik" Text="0/100" Foreground="White" 
                                   FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtMaliSaglikSeviye" Text="-" Foreground="#CFD8DC" FontSize="10"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Grafikler Satir 1 -->
            <Grid Grid.Row="2" Height="280" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Gelir/Gider Trend Grafigi -->
                <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,10,0" Padding="15"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.1" BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="📊 Aylik Gelir/Gider Trendi" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                        <lvc:CartesianChart x:Name="chartGelirGider" Grid.Row="1" Margin="0,10,0,0"/>
                    </Grid>
                </Border>

                <!-- Gider Dagilimi Pasta Grafik -->
                <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.1" BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="🥧 Gider Dagilimi" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                        <lvc:PieChart x:Name="chartGiderDagilimi" Grid.Row="1" Margin="0,10,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Grafikler Satir 2 -->
            <Grid Grid.Row="3" Height="280" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Mali Oranlar -->
                <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,10,0" Padding="15"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.1" BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📈 Mali Oranlar" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cari Oran" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="txtCariOran" Grid.Column="1" Text="0.00" Foreground="#4CAF50" FontWeight="Bold" FontSize="16"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Asit Test Orani" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="txtAsitTest" Grid.Column="1" Text="0.00" Foreground="#4CAF50" FontWeight="Bold" FontSize="16"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Borc/Ozkaynak" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="txtBorcOzkaynak" Grid.Column="1" Text="0.00" Foreground="#FF9800" FontWeight="Bold" FontSize="16"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ROE" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="txtROE" Grid.Column="1" Text="%0" Foreground="#4CAF50" FontWeight="Bold" FontSize="16"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ROA" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="txtROA" Grid.Column="1" Text="%0" Foreground="#4CAF50" FontWeight="Bold" FontSize="16"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Son Islemler -->
                <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,10,0" Padding="15"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.1" BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="📝 Son Islemler" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <ListBox x:Name="lstSonIslemler" Grid.Row="1" Background="Transparent" BorderThickness="0"/>
                    </Grid>
                </Border>

                <!-- Hatirlatmalar -->
                <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.1" BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="🔔 Hatirlatmalar" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <StackPanel x:Name="pnlHatirlatmalar" Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
