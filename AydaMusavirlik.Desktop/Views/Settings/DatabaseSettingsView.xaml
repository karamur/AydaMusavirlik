<UserControl x:Class="AydaMusavirlik.Desktop.Views.Settings.DatabaseSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Veritabani Ayarlari" FontSize="24" FontWeight="Bold" 
                       Foreground="White" Margin="0,0,0,20"/>

            <!-- Veritabani Secimi -->
            <Border Grid.Row="1" Background="#2D2D30" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Veritabani Turu" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <RadioButton x:Name="rbSqlite" Content="SQLite" Foreground="White" 
                                     GroupName="DbType" IsChecked="True" Margin="0,0,20,0"
                                     Checked="DatabaseType_Changed"/>
                        <RadioButton x:Name="rbSqlServer" Content="SQL Server" Foreground="White" 
                                     GroupName="DbType" Margin="0,0,20,0"
                                     Checked="DatabaseType_Changed"/>
                        <RadioButton x:Name="rbPostgres" Content="PostgreSQL" Foreground="White" 
                                     GroupName="DbType"
                                     Checked="DatabaseType_Changed"/>
                    </StackPanel>

                    <!-- SQLite Ayarlari -->
                    <Border x:Name="pnlSqlite" Background="#3A3A3A" CornerRadius="4" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="SQLite Veritabani Dosyasi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtSqlitePath" Background="#2D2D30" Foreground="White" 
                                         BorderBrush="#555" Padding="8" Text="AydaMusavirlik.db"/>
                                <Button Grid.Column="1" Content="Gozat..." Margin="10,0,0,0" Padding="15,8"
                                        Background="#007ACC" Foreground="White" Click="BrowseSqlite_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SQL Server Ayarlari -->
                    <Border x:Name="pnlSqlServer" Background="#3A3A3A" CornerRadius="4" Padding="15" Margin="0,10,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Sunucu Adresi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtSqlServerHost" Background="#2D2D30" Foreground="White" 
                                             BorderBrush="#555" Padding="8" Text="localhost"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Port" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtSqlServerPort" Background="#2D2D30" Foreground="White" 
                                             BorderBrush="#555" Padding="8" Text="1433"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Veritabani Adi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtSqlServerDb" Background="#2D2D30" Foreground="White" 
                                     BorderBrush="#555" Padding="8" Text="AydaMusavirlik" Margin="0,0,0,10"/>

                            <CheckBox x:Name="chkTrustedConnection" Content="Windows Kimlik Dogrulama" 
                                      Foreground="White" IsChecked="True" Margin="0,0,0,10"
                                      Checked="TrustedConnection_Changed" Unchecked="TrustedConnection_Changed"/>

                            <StackPanel x:Name="pnlSqlServerAuth" Visibility="Collapsed">
                                <TextBlock Text="Kullanici Adi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSqlServerUser" Background="#2D2D30" Foreground="White" 
                                         BorderBrush="#555" Padding="8" Margin="0,0,0,10"/>

                                <TextBlock Text="Sifre" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="txtSqlServerPass" Background="#2D2D30" Foreground="White" 
                                             BorderBrush="#555" Padding="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PostgreSQL Ayarlari -->
                    <Border x:Name="pnlPostgres" Background="#3A3A3A" CornerRadius="4" Padding="15" Margin="0,10,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Sunucu Adresi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtPostgresHost" Background="#2D2D30" Foreground="White" 
                                             BorderBrush="#555" Padding="8" Text="localhost"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Port" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtPostgresPort" Background="#2D2D30" Foreground="White" 
                                             BorderBrush="#555" Padding="8" Text="5432"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Veritabani Adi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPostgresDb" Background="#2D2D30" Foreground="White" 
                                     BorderBrush="#555" Padding="8" Text="aydamusavirlik" Margin="0,0,0,10"/>

                            <TextBlock Text="Kullanici Adi" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPostgresUser" Background="#2D2D30" Foreground="White" 
                                     BorderBrush="#555" Padding="8" Text="postgres" Margin="0,0,0,10"/>

                            <TextBlock Text="Sifre" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="txtPostgresPass" Background="#2D2D30" Foreground="White" 
                                         BorderBrush="#555" Padding="8"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Butonlar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                <Button x:Name="btnTestConnection" Content="Baglanti Test Et" 
                        Background="#FF9800" Foreground="White" Padding="20,10"
                        Click="TestConnection_Click"/>
                <Button x:Name="btnSave" Content="Kaydet ve Baglan" Margin="15,0,0,0"
                        Background="#4CAF50" Foreground="White" Padding="20,10"
                        Click="Save_Click"/>
                <Button x:Name="btnCreateDb" Content="Veritabani Olustur" Margin="15,0,0,0"
                        Background="#2196F3" Foreground="White" Padding="20,10"
                        Click="CreateDatabase_Click"/>
            </StackPanel>

            <!-- Durum Bilgisi -->
            <Border Grid.Row="3" x:Name="brdStatus" Background="#2D2D30" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Baglanti Durumu" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Durum:" Foreground="LightGray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtStatus" Text="Bagli Degil" Foreground="Orange" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Text="Veritabani:" Foreground="LightGray" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDbProvider" Text="-" Foreground="White" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Text="Baglanti:" Foreground="LightGray" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtConnectionString" Text="-" Foreground="White" 
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="3" Text="Firma Sayisi:" Foreground="LightGray" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtCompanyCount" Text="-" Foreground="White" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="4" Text="Hesap Sayisi:" Foreground="LightGray" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtAccountCount" Text="-" Foreground="White" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="5" Text="Kayit Sayisi:" Foreground="LightGray" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtRecordCount" Text="-" Foreground="White" Margin="0,8,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Mesaj -->
            <Border Grid.Row="4" x:Name="brdMessage" Background="#3A3A3A" CornerRadius="4" Padding="15" 
                    Visibility="Collapsed" VerticalAlignment="Top">
                <TextBlock x:Name="txtMessage" Foreground="White" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>