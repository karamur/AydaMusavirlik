<Window x:Class="AydaMusavirlik.Desktop.Views.Payroll.EmailSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-posta G—nder" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ba±l»k -->
        <TextBlock Text="?? ïzin Formu E-posta G—nder" FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <!-- Al»c» -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Al»c»:" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtAlici" Grid.Column="1" Padding="10,8"/>
        </Grid>

        <!-- Konu -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Konu:" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtKonu" Grid.Column="1" Padding="10,8"/>
        </Grid>

        <!-- Mesaj -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mesaj:" VerticalAlignment="Top" FontWeight="SemiBold"/>
            <TextBox x:Name="txtMesaj" Grid.Column="1" Padding="10,8" 
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- Ek Bilgi -->
        <Border Grid.Row="4" Background="#E3F2FD" Padding="10" CornerRadius="4" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="?? Ek: ïzin Formu PDF" FontWeight="SemiBold"/>
                <TextBlock x:Name="txtFormNo" Text="IZN-2025-001.pdf" FontSize="11" Foreground="#666"/>
            </StackPanel>
        </Border>

        <!-- Butonlar -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ïptal" Padding="20,10" Margin="0,0,10,0" Click="BtnIptal_Click"/>
            <Button x:Name="btnGonder" Content="?? G—nder" Padding="20,10" 
                    Background="#1976D2" Foreground="White" Click="BtnGonder_Click"/>
        </StackPanel>
    </Grid>
</Window>