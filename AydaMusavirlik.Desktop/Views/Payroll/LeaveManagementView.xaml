<UserControl x:Class="AydaMusavirlik.Desktop.Views.Payroll.LeaveManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Izin Yonetimi" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="Personel izin taleplerini goruntuleyin ve yonetin" 
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="cmbDurum" Width="150" Margin="0,0,10,0"
                      SelectionChanged="CmbDurum_SelectionChanged">
                <ComboBoxItem Content="Tum Talepler" IsSelected="True"/>
                <ComboBoxItem Content="Bekleyenler"/>
                <ComboBoxItem Content="Onaylananlar"/>
                <ComboBoxItem Content="Reddedilenler"/>
            </ComboBox>

            <DatePicker x:Name="dpBaslangic" Width="130" Margin="0,0,5,0" Grid.Column="1"/>
            <DatePicker x:Name="dpBitis" Width="130" Margin="0,0,10,0" Grid.Column="2"/>

            <TextBox x:Name="txtArama" Grid.Column="3" Margin="0,0,10,0" Text=""/>

            <Button Grid.Column="4" Content="Yenile" Padding="15,8" Click="BtnYenile_Click"/>
        </Grid>

        <TabControl Grid.Row="2">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Bekleyen Talepler" VerticalAlignment="Center"/>
                        <Border Background="#FF9800" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                            <TextBlock x:Name="txtBekleyenSayisi" Text="3" Foreground="White" FontWeight="Bold" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <DataGrid x:Name="dgBekleyenTalepler" AutoGenerateColumns="False" 
                              IsReadOnly="True" SelectionMode="Single"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Form No" Binding="{Binding FormNo}" Width="100"/>
                            <DataGridTextColumn Header="Personel" Binding="{Binding PersonelAdi}" Width="150"/>
                            <DataGridTextColumn Header="Izin Turu" Binding="{Binding IzinTuru}" Width="100"/>
                            <DataGridTextColumn Header="Baslangic" Binding="{Binding BaslangicTarihi, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Bitis" Binding="{Binding BitisTarihi, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Gun" Binding="{Binding GunSayisi}" Width="50"/>
                            <DataGridTextColumn Header="Talep Tarihi" Binding="{Binding TalepTarihi, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTemplateColumn Header="Islemler" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Onayla" Background="#4CAF50" Foreground="White" 
                                                    Padding="8,4" Margin="0,0,5,0"
                                                    Click="BtnOnayla_Click" Tag="{Binding Id}"/>
                                            <Button Content="Reddet" Background="#F44336" Foreground="White" 
                                                    Padding="8,4" Margin="0,0,5,0"
                                                    Click="BtnReddet_Click" Tag="{Binding Id}"/>
                                            <Button Content="Detay" Padding="8,4"
                                                    Click="BtnDetay_Click" Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Tum Talepler">
                <Grid>
                    <DataGrid x:Name="dgTumTalepler" AutoGenerateColumns="False" 
                              IsReadOnly="True" SelectionMode="Single"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Form No" Binding="{Binding FormNo}" Width="100"/>
                            <DataGridTextColumn Header="Personel" Binding="{Binding PersonelAdi}" Width="150"/>
                            <DataGridTextColumn Header="Izin Turu" Binding="{Binding IzinTuru}" Width="100"/>
                            <DataGridTextColumn Header="Baslangic" Binding="{Binding BaslangicTarihi, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Bitis" Binding="{Binding BitisTarihi, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Gun" Binding="{Binding GunSayisi}" Width="50"/>
                            <DataGridTemplateColumn Header="Durum" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding DurumRenk}" CornerRadius="4" Padding="8,3">
                                            <TextBlock Text="{Binding Durum}" Foreground="White" FontWeight="SemiBold" 
                                                       HorizontalAlignment="Center" FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Onaylayan" Binding="{Binding OnaylayanAdi}" Width="120"/>
                            <DataGridTemplateColumn Header="Islemler" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="D" ToolTip="Detay" Padding="6,4" Margin="0,0,3,0"
                                                    Click="BtnDetay_Click" Tag="{Binding Id}"/>
                                            <Button Content="P" ToolTip="Yazdir" Padding="6,4" Margin="0,0,3,0"
                                                    Click="BtnYazdir_Click" Tag="{Binding Id}"
                                                    IsEnabled="{Binding Onaylandi}"/>
                                            <Button Content="M" ToolTip="Mail Gonder" Padding="6,4" Margin="0,0,3,0"
                                                    Click="BtnMailGonder_Click" Tag="{Binding Id}"
                                                    IsEnabled="{Binding Onaylandi}"/>
                                            <Button Content="F" ToolTip="PDF Indir" Padding="6,4"
                                                    Click="BtnPdfIndir_Click" Tag="{Binding Id}"
                                                    IsEnabled="{Binding Onaylandi}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Personel Izin Ozeti">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Personel Sec:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cmbPersonel" Width="250" SelectionChanged="CmbPersonel_SelectionChanged"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Toplam Hak Edilen Izin" FontWeight="SemiBold" Foreground="#1565C0"/>
                                    <TextBlock x:Name="txtToplamHakedilen" Text="20 gun" FontSize="24" FontWeight="Bold" 
                                               Foreground="#1976D2" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Kullanilan Izin" FontWeight="SemiBold" Foreground="#2E7D32"/>
                                    <TextBlock x:Name="txtKullanilan" Text="8 gun" FontSize="24" FontWeight="Bold" 
                                               Foreground="#4CAF50" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FFF3E0" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Kalan Izin" FontWeight="SemiBold" Foreground="#E65100"/>
                                    <TextBlock x:Name="txtKalan" Text="12 gun" FontSize="24" FontWeight="Bold" 
                                               Foreground="#FF9800" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <DataGrid x:Name="dgPersonelIzinleri" Grid.Column="1" AutoGenerateColumns="False" 
                                  IsReadOnly="True" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Form No" Binding="{Binding FormNo}" Width="100"/>
                                <DataGridTextColumn Header="Izin Turu" Binding="{Binding IzinTuru}" Width="100"/>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding TarihAraligi}" Width="180"/>
                                <DataGridTextColumn Header="Gun" Binding="{Binding GunSayisi}" Width="50"/>
                                <DataGridTextColumn Header="Durum" Binding="{Binding Durum}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>