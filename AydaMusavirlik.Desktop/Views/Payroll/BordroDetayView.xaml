<UserControl x:Class="AydaMusavirlik.Desktop.Views.Payroll.BordroDetayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1400"
             Background="#1E1E1E">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Baslik -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtBaslik" Text="Bordro Hesaplama" FontSize="22" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="txtDonem" Text="Donem: 2025/01" Foreground="Gray" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Ozet Kartlar -->
        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <WrapPanel>
                <Border Background="#007ACC" CornerRadius="5" Padding="15" Margin="0,0,15,0" MinWidth="150">
                    <StackPanel>
                        <TextBlock Text="Personel Sayisi" Foreground="White" FontSize="11"/>
                        <TextBlock x:Name="txtPersonelSayisi" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#4CAF50" CornerRadius="5" Padding="15" Margin="0,0,15,0" MinWidth="180">
                    <StackPanel>
                        <TextBlock Text="Toplam Brut" Foreground="White" FontSize="11"/>
                        <TextBlock x:Name="txtToplamBrut" Text="0 TL" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#FF9800" CornerRadius="5" Padding="15" Margin="0,0,15,0" MinWidth="180">
                    <StackPanel>
                        <TextBlock Text="Toplam Net" Foreground="White" FontSize="11"/>
                        <TextBlock x:Name="txtToplamNet" Text="0 TL" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#9C27B0" CornerRadius="5" Padding="15" Margin="0,0,15,0" MinWidth="180">
                    <StackPanel>
                        <TextBlock Text="SGK Isveren" Foreground="White" FontSize="11"/>
                        <TextBlock x:Name="txtSgkIsveren" Text="0 TL" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#E91E63" CornerRadius="5" Padding="15" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="Toplam Maliyet" Foreground="White" FontSize="11"/>
                        <TextBlock x:Name="txtToplamMaliyet" Text="0 TL" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Bordro Tablosu -->
        <DataGrid x:Name="dgBordro" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="#252526" 
                  Foreground="White"
                  GridLinesVisibility="All"
                  BorderThickness="1"
                  BorderBrush="#3E3E42"
                  RowBackground="#2D2D30"
                  AlternatingRowBackground="#252526"
                  HeadersVisibility="Column"
                  FontSize="11">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ad Soyad" Binding="{Binding EmployeeName}" Width="150"/>
                <DataGridTextColumn Header="Belge" Binding="{Binding BelgeTuruKod}" Width="50"/>
                <DataGridTextColumn Header="Gun" Binding="{Binding CalismaGunu}" Width="40"/>
                <DataGridTextColumn Header="Brut Ucret" Binding="{Binding BrutUcret, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="F.Mesai" Binding="{Binding FazlaMesaiUcreti, StringFormat=N2}" Width="70"/>
                <DataGridTextColumn Header="Top.Kazanc" Binding="{Binding ToplamKazanc, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="SGK Isci" Binding="{Binding SgkIsciPayi, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Issizlik" Binding="{Binding IssizlikIsciPayi, StringFormat=N2}" Width="70"/>
                <DataGridTextColumn Header="G.Vergisi" Binding="{Binding GelirVergisi, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Damga" Binding="{Binding DamgaVergisi, StringFormat=N2}" Width="70"/>
                <DataGridTextColumn Header="Kesintiler" Binding="{Binding ToplamKesinti, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="Net Ucret" Binding="{Binding NetUcret, StringFormat=N2}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#4CAF50"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="SGK Isv." Binding="{Binding SgkIsverenPayi, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Issiz.Isv." Binding="{Binding IssizlikIsverenPayi, StringFormat=N2}" Width="75"/>
                <DataGridTextColumn Header="Isv.Maliyet" Binding="{Binding ToplamIsverenMaliyeti, StringFormat=N2}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#E91E63"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Vergi/SGK Ozet -->
        <Border Grid.Row="3" Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="SGK KESINTILERI" Foreground="#007ACC" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtSgkIsciToplam" Text="SGK Isci: 0 TL" Foreground="White"/>
                    <TextBlock x:Name="txtSgkIsverenToplam" Text="SGK Isveren: 0 TL" Foreground="White"/>
                    <TextBlock x:Name="txtIssizlikToplam" Text="Issizlik: 0 TL" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="VERGI KESINTILERI" Foreground="#FF9800" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtGelirVergisiToplam" Text="Gelir Vergisi: 0 TL" Foreground="White"/>
                    <TextBlock x:Name="txtDamgaVergisiToplam" Text="Damga Vergisi: 0 TL" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="ODENECEK" Foreground="#4CAF50" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtSgkOdenecek" Text="SGK Toplam: 0 TL" Foreground="White"/>
                    <TextBlock x:Name="txtVergiOdenecek" Text="Vergi Toplam: 0 TL" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Alt Butonlar -->
        <Border Grid.Row="4" Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnExcelExport" Content="Excel Export" Width="110" Margin="0,0,10,0"
                        Click="BtnExcelExport_Click" Background="#4CAF50" Foreground="White"/>
                <Button x:Name="btnPdfExport" Content="PDF Export" Width="100" Margin="0,0,10,0"
                        Click="BtnPdfExport_Click" Background="#E91E63" Foreground="White"/>
                <Button x:Name="btnSgkBildirge" Content="SGK Bildirge" Width="110" Margin="0,0,10,0"
                        Click="BtnSgkBildirge_Click" Background="#9C27B0" Foreground="White"/>
                <Button x:Name="btnKaydet" Content="Kaydet" Width="100"
                        Click="BtnKaydet_Click" Background="#007ACC" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>