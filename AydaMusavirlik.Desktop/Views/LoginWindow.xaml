<Window x:Class="AydaMusavirlik.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Ayda Müşavirlik - Giriş" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="20">
            <StackPanel HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="AccountTie" Width="48" Height="48" 
                                          Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="AYDA MÜŞAVİRLİK" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <TextBlock Text="Mali Müşavirlik Yazılımı" 
                           FontSize="12" Foreground="White" 
                           HorizontalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="40">

            <TextBox x:Name="txtUsername"
                     materialDesign:HintAssist.Hint="Kullanıcı Adı"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,20"/>

            <PasswordBox x:Name="txtPassword"
                         materialDesign:HintAssist.Hint="Şifre"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         Margin="0,0,0,20"
                         KeyDown="TxtPassword_KeyDown"/>

            <TextBlock x:Name="txtError" 
                       Foreground="Red" 
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <Button x:Name="btnLogin"
                    Content="GİRİŞ YAP"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Height="40"
                    Click="BtnLogin_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock Text="API Durumu: " VerticalAlignment="Center"/>
                <Ellipse x:Name="statusIndicator" Width="10" Height="10" Fill="Gray" Margin="5,0"/>
                <TextBlock x:Name="txtStatus" Text="Kontrol ediliyor..." VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>