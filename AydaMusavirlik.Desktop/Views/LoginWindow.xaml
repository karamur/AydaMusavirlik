<Window x:Class="AydaMusavirlik.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayda Müşavirlik - Giriş" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="12" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Panel - Görsel -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1976D2" Offset="0"/>
                        <GradientStop Color="#1565C0" Offset="0.5"/>
                        <GradientStop Color="#0D47A1" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="🏢" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="AYDA MÜŞAVİRLİK" FontSize="32" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Profesyonel Mali Müşavirlik Yazılımı" FontSize="14" 
                                   Foreground="White" Opacity="0.8" HorizontalAlignment="Center" Margin="0,10,0,30"/>
                        
                        <Border Background="White" Opacity="0.15" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="✓ Muhasebe ve Fiş Yönetimi" Foreground="White" FontSize="13" Margin="0,5"/>
                                <TextBlock Text="✓ Bordro ve SGK İşlemleri" Foreground="White" FontSize="13" Margin="0,5"/>
                                <TextBlock Text="✓ Mali Analiz ve Raporlama" Foreground="White" FontSize="13" Margin="0,5"/>
                                <TextBlock Text="✓ AR-GE Proje Takibi" Foreground="White" FontSize="13" Margin="0,5"/>
                                <TextBlock Text="✓ Web Portal Entegrasyonu" Foreground="White" FontSize="13" Margin="0,5"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <!-- Versiyon -->
                    <TextBlock Text="v1.0.0" Foreground="White" Opacity="0.5" FontSize="11"
                               VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20"/>
                </Grid>
            </Border>

            <!-- Sağ Panel - Giriş Formu -->
            <Grid Grid.Column="1" Margin="40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Kapat Butonu -->
                <Button Grid.Row="0" Content="✕" HorizontalAlignment="Right" 
                        Background="Transparent" BorderThickness="0" FontSize="16"
                        Foreground="Gray" Cursor="Hand" Width="30" Height="30"
                        Click="BtnClose_Click"/>

                <!-- Form -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Hoş Geldiniz" FontSize="26" FontWeight="Bold" 
                               Foreground="#212121" Margin="0,0,0,5"/>
                    <TextBlock Text="Hesabınıza giriş yapın" FontSize="13" 
                               Foreground="#757575" Margin="0,0,0,30"/>

                    <!-- Kullanıcı Adı -->
                    <TextBlock Text="Kullanıcı Adı" Foreground="#424242" FontWeight="Medium" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" Margin="12,0"/>
                            <TextBox x:Name="txtUsername" Grid.Column="1" 
                                     BorderThickness="0" Padding="8,12" FontSize="14"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <!-- Şifre -->
                    <TextBlock Text="Şifre" Foreground="#424242" FontWeight="Medium" Margin="0,20,0,8"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" Margin="12,0"/>
                            <PasswordBox x:Name="txtPassword" Grid.Column="1" 
                                         BorderThickness="0" Padding="8,12" FontSize="14"
                                         Background="Transparent" KeyDown="TxtPassword_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Hata Mesajı -->
                    <Border x:Name="brdError" Visibility="Collapsed" Background="#FFEBEE" 
                            CornerRadius="6" Padding="12" Margin="0,15,0,0">
                        <TextBlock x:Name="txtError" Foreground="#C62828" TextWrapping="Wrap" FontSize="12"/>
                    </Border>

                    <!-- Giriş Butonu -->
                    <Button x:Name="btnLogin" Content="GİRİŞ YAP" Margin="0,25,0,0"
                            Height="45" FontSize="14" FontWeight="Bold"
                            Foreground="White" Cursor="Hand" Click="BtnLogin_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1565C0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Beni Hatırla -->
                    <CheckBox Content="Beni hatırla" Margin="0,15,0,0" Foreground="#616161"/>
                </StackPanel>

                <!-- Alt Bilgi -->
                <StackPanel Grid.Row="2">
                    <!-- Veritabanı Durumu -->
                    <Border x:Name="brdDbStatus" Background="#F5F5F5" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="dbStatusIndicator" Width="10" Height="10" Fill="#9E9E9E" 
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="txtDbStatus" Text="Veritabanı kontrol ediliyor..." 
                                           FontSize="12" Foreground="#424242"/>
                                <TextBlock x:Name="txtDbInfo" Text="" FontSize="10" Foreground="#9E9E9E"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Demo Bilgisi -->
                    <Border Background="#E3F2FD" CornerRadius="6" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Demo Hesaplar:" FontWeight="Medium" FontSize="11" Foreground="#1565C0"/>
                            <TextBlock Text="admin / Admin123!" FontSize="10" Foreground="#1976D2" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="© 2025 Ayda Müşavirlik" HorizontalAlignment="Center" 
                               FontSize="10" Foreground="#9E9E9E" Margin="0,15,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
