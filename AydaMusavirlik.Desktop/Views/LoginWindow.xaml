<Window x:Class="AydaMusavirlik.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayda Musavirlik - Giris" 
        Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1976D2" Padding="20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="AYDA MUSAVIRLIK" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Profesyonel Mali Musavirlik Yazilimi" 
                           FontSize="12" Foreground="White" 
                           HorizontalAlignment="Center" Opacity="0.8"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <Border Grid.Row="1" Background="White" Margin="20" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center" Margin="30">

                <TextBlock Text="Kullanici Adi" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUsername"
                         Padding="10"
                         FontSize="14"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Sifre" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtPassword"
                             Padding="10"
                             FontSize="14"
                             Margin="0,0,0,15"
                             KeyDown="TxtPassword_KeyDown"/>

                <TextBlock x:Name="txtError" 
                           Foreground="Red" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="Collapsed"/>

                <Button x:Name="btnLogin"
                        Content="GIRIS YAP"
                        Background="#1976D2"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="15,10"
                        Cursor="Hand"
                        Click="BtnLogin_Click"/>

                <Border Background="#E3F2FD" Margin="0,20,0,0" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Test Kullanicilari:" FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,5"/>
                        <TextBlock Text="admin / admin" FontSize="11" Foreground="#424242"/>
                        <TextBlock Text="muhasebe / muhasebe" FontSize="11" Foreground="#424242"/>
                        <TextBlock Text="yonetici / yonetici" FontSize="11" Foreground="#424242"/>
                        <TextBlock Text="test / test" FontSize="11" Foreground="#424242"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock Text="Durum: " VerticalAlignment="Center" FontSize="11"/>
                    <Ellipse x:Name="statusIndicator" Width="8" Height="8" Fill="Green" Margin="5,0"/>
                    <TextBlock x:Name="txtStatus" Text="Hazir" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
