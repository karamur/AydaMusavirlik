<UserControl x:Class="AydaMusavirlik.Desktop.Views.Reports.FinancialAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Mali Analiz Raporu" FontSize="24" FontWeight="Bold" Foreground="White"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnAnalizYap" Content="Analiz Yap" Click="AnalizYap_Click"
                            Background="#007ACC" Foreground="White" Padding="15,8" Margin="5,0"/>
                    <Button x:Name="btnPdfExport" Content="PDF" Click="PdfExport_Click"
                            Background="#4CAF50" Foreground="White" Padding="15,8" Margin="5,0"/>
                    <Button x:Name="btnExcelExport" Content="Excel" Click="ExcelExport_Click"
                            Background="#2E7D32" Foreground="White" Padding="15,8" Margin="5,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" x:Name="brdMaliSaglik" Background="#4A4A4A" CornerRadius="12" 
                    Padding="25" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="120" Height="120" CornerRadius="60" BorderThickness="6"
                            BorderBrush="#007ACC" Background="#2D2D30">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="txtSkor" Text="78" FontSize="36" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="/ 100" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="25,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtDerece" Text="Mali Saglik Derecesi: B+" 
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="txtYorum" Text="Iyi mali saglik. Bazi alanlarda iyilestirme yapilabilir." 
                                   FontSize="13" Foreground="LightGray" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        
                        <UniformGrid Columns="4" Margin="0,15,0,0">
                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Likidite" Foreground="Gray" FontSize="11"/>
                                <TextBlock x:Name="txtLikiditePuan" Text="20/25" Foreground="LightGreen" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Karlilik" Foreground="Gray" FontSize="11"/>
                                <TextBlock x:Name="txtKarlilikPuan" Text="18/25" Foreground="LightGreen" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Borcluluk" Foreground="Gray" FontSize="11"/>
                                <TextBlock x:Name="txtBorclulukPuan" Text="22/25" Foreground="LightGreen" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Verimlilik" Foreground="Gray" FontSize="11"/>
                                <TextBlock x:Name="txtVerimlilikPuan" Text="18/25" Foreground="Yellow" FontWeight="Bold"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Likidite Oranlari" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cari Oran" Foreground="LightGray"/>
                            <TextBlock x:Name="txtCariOran" Grid.Column="1" Text="1.85" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Iyi" Foreground="LightGreen" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Asit Test Orani" Foreground="LightGray"/>
                            <TextBlock x:Name="txtAsitTest" Grid.Column="1" Text="1.42" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Iyi" Foreground="LightGreen" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nakit Orani" Foreground="LightGray"/>
                            <TextBlock x:Name="txtNakitOran" Grid.Column="1" Text="0.35" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Iyi" Foreground="LightGreen" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Net Isletme Sermayesi" Foreground="LightGray"/>
                            <TextBlock x:Name="txtNetIsletmeSermayesi" Grid.Column="1" Text="580.000 TL" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Karlilik Oranlari" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Brut Kar Marji" Foreground="LightGray"/>
                            <TextBlock x:Name="txtBrutKarMarji" Grid.Column="1" Text="%28.5" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Net Kar Marji" Foreground="LightGray"/>
                            <TextBlock x:Name="txtNetKarMarji" Grid.Column="1" Text="%21.6" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ozkaynak Karliligi (ROE)" Foreground="LightGray"/>
                            <TextBlock x:Name="txtROE" Grid.Column="1" Text="%18.5" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Aktif Karliligi (ROA)" Foreground="LightGray"/>
                            <TextBlock x:Name="txtROA" Grid.Column="1" Text="%12.3" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Borcluluk Oranlari" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Borc/Ozkaynak Orani" Foreground="LightGray"/>
                            <TextBlock x:Name="txtBorcOzkaynak" Grid.Column="1" Text="0.65" Foreground="Yellow" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Toplam Borc Orani" Foreground="LightGray"/>
                            <TextBlock x:Name="txtToplamBorc" Grid.Column="1" Text="%39.4" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ozkaynak Orani" Foreground="LightGray"/>
                            <TextBlock x:Name="txtOzkaynakOrani" Grid.Column="1" Text="%60.6" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Finansal Kaldirac" Foreground="LightGray"/>
                            <TextBlock x:Name="txtFinansalKaldirac" Grid.Column="1" Text="1.65" Foreground="Yellow" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Background="#2D2D30" CornerRadius="8" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Verimlilik Oranlari" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stok Devir Hizi" Foreground="LightGray"/>
                            <TextBlock x:Name="txtStokDevir" Grid.Column="1" Text="5.2 kez" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stok Devir Suresi" Foreground="LightGray"/>
                            <TextBlock x:Name="txtStokDevirSure" Grid.Column="1" Text="70 gun" Foreground="Yellow" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Alacak Tahsil Suresi" Foreground="LightGray"/>
                            <TextBlock x:Name="txtAlacakTahsil" Grid.Column="1" Text="45 gun" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Aktif Devir Hizi" Foreground="LightGray"/>
                            <TextBlock x:Name="txtAktifDevir" Grid.Column="1" Text="1.35 kez" Foreground="LightGreen" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
