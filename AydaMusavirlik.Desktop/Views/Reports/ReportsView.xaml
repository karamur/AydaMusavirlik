<UserControl x:Class="AydaMusavirlik.Desktop.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#252526">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Baslik -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Raporlar" FontSize="24" Foreground="White" FontWeight="Bold"/>
            <TextBlock Text="Mali tablolar ve raporlari olusturun" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Rapor Kategorileri -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Mali Tablolar -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Mali Tablolar" FontSize="18" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <WrapPanel>
                            <Button x:Name="btnBilanco" Content="Bilanco" Click="Bilanco_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#007ACC" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnGelirTablosu" Content="Gelir Tablosu" Click="GelirTablosu_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#007ACC" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnMizan" Content="Mizan" Click="Mizan_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#007ACC" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnKebir" Content="Kebir Defteri" Click="Kebir_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#007ACC" Foreground="White" FontSize="14"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Bordro Raporlari -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Bordro Raporlari" FontSize="18" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <WrapPanel>
                            <Button x:Name="btnBordroOzet" Content="Aylik Bordro (Excel)" Click="BordroOzet_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#4CAF50" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnBordroPdf" Content="Aylik Bordro (PDF)" Click="BordroPdf_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#E91E63" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnBordroDetay" Content="Personel Bordro Detay" Click="BordroDetay_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#4CAF50" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnSgkBildirge" Content="SGK Bildirge" Click="SgkBildirge_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#4CAF50" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnMuhtasar" Content="Muhtasar Beyanname" Click="Muhtasar_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#4CAF50" Foreground="White" FontSize="14"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Vergi Raporlari -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Vergi Raporlari" FontSize="18" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <WrapPanel>
                            <Button x:Name="btnKdvBeyan" Content="KDV Beyannamesi" Click="KdvBeyan_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#FF9800" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnGeciciVergi" Content="Gecici Vergi" Click="GeciciVergi_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#FF9800" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnBaBeFormlar" Content="Ba-Bs Formlari" Click="BaBeFormlar_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#FF9800" Foreground="White" FontSize="14"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Diger Raporlar -->
                <Border Background="#2D2D30" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Diger Raporlar" FontSize="18" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <WrapPanel>
                            <Button x:Name="btnCariHesap" Content="Cari Hesap Ekstre" Click="CariHesap_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#9C27B0" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnFirmaKarti" Content="Firma Karti" Click="FirmaKarti_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#9C27B0" Foreground="White" FontSize="14"/>
                            <Button x:Name="btnPersonelListe" Content="Personel Listesi" Click="PersonelListe_Click"
                                    Width="200" Height="80" Margin="0,0,15,15"
                                    Background="#9C27B0" Foreground="White" FontSize="14"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>