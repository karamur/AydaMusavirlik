@inherits LayoutComponentBase
@inject ModuleService ModuleService
@inject LicenseService LicenseService
@inject AuthenticationService AuthService
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!AuthService.IsAuthenticated)
{
    <RedirectToLogin />
}
else
{
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                           OnClick="@(() => _drawerOpen = !_drawerOpen)" />
            <MudText Typo="Typo.h5" Class="ml-3">AYDA Müţavirlik</MudText>
            <MudSpacer />

            @* Lisans Durumu *@
            <MudChip T="string" Color="@GetLicenseColor()" Size="Size.Small" Class="mr-4">
                @GetLicenseText()
            </MudChip>

            @* Kullanýcý Menüsü *@
            <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                <MudMenuItem>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.subtitle1">@AuthService.CurrentUser?.FullName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@GetRoleText()</MudText>
                    </div>
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Href="/profil" Icon="@Icons.Material.Filled.AccountCircle">Profil</MudMenuItem>
                <MudMenuItem Href="/ayarlar" Icon="@Icons.Material.Filled.Settings">Ayarlar</MudMenuItem>
                @if (AuthService.IsAdmin)
                {
                    <MudMenuItem Href="/kullanicilar" Icon="@Icons.Material.Filled.People">Kullanýcý Yönetimi</MudMenuItem>
                }
                <MudDivider />
                <MudMenuItem OnClick="HandleLogout" Icon="@Icons.Material.Filled.Logout">Çýkýţ Yap</MudMenuItem>
            </MudMenu>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini" 
                   OpenMiniOnHover="true" ClipMode="DrawerClipMode.Always">
            <MudDrawerHeader>
                <MudText Typo="Typo.h6">Menü</MudText>
            </MudDrawerHeader>
            <MudNavMenu>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                    Ana Sayfa
                </MudNavLink>

                @* Dinamik Modül Menüleri *@
                @foreach (var module in LicensedModules)
                {
                    <MudNavGroup Title="@module.ModuleName" Icon="@GetModuleIcon(module.Icon)" Expanded="false">
                        @foreach (var menuItem in module.MenuItems)
                        {
                            @if (menuItem.Children.Count > 0)
                            {
                                <MudNavGroup Title="@menuItem.Title" Icon="@GetModuleIcon(menuItem.Icon)">
                                    @foreach (var child in menuItem.Children)
                                    {
                                        <MudNavLink Href="@child.Route" Icon="@GetModuleIcon(child.Icon)">
                                            @child.Title
                                        </MudNavLink>
                                    }
                                </MudNavGroup>
                            }
                            else
                            {
                                <MudNavLink Href="@menuItem.Route" Icon="@GetModuleIcon(menuItem.Icon)">
                                    @menuItem.Title
                                </MudNavLink>
                            }
                        }
                    </MudNavGroup>
                }

                <MudDivider Class="my-2" />

                @if (AuthService.IsAdmin)
                {
                    <MudNavLink Href="/kullanicilar" Icon="@Icons.Material.Filled.People">
                        Kullanýcý Yönetimi
                    </MudNavLink>
                }
            </MudNavMenu>
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}

@code {
    private bool _drawerOpen = true;
    private IReadOnlyList<ModuleInfo> LicensedModules => ModuleService.GetLicensedModules();

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#424242",
            AppbarBackground = "#1976D2"
        }
    };

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private string GetRoleText()
    {
        return AuthService.CurrentUser?.Role switch
        {
            UserRole.Admin => "Sistem Yöneticisi",
            UserRole.Manager => "Yönetici",
            UserRole.Accountant => "Muhasebeci",
            UserRole.Auditor => "Denetçi",
            UserRole.User => "Kullanýcý",
            _ => "Misafir"
        };
    }

    private string GetModuleIcon(string iconName)
    {
        return iconName switch
        {
            "Calculator" => Icons.Material.Filled.Calculate,
            "Users" => Icons.Material.Filled.People,
            "Search" => Icons.Material.Filled.Search,
            "BarChart" => Icons.Material.Filled.BarChart,
            "Lightbulb" => Icons.Material.Filled.Lightbulb,
            "Building" => Icons.Material.Filled.Business,
            "Dashboard" => Icons.Material.Filled.Dashboard,
            "FileText" => Icons.Material.Filled.Description,
            "List" => Icons.Material.Filled.List,
            "TrendingUp" => Icons.Material.Filled.TrendingUp,
            "TrendingDown" => Icons.Material.Filled.TrendingDown,
            "PieChart" => Icons.Material.Filled.PieChart,
            "Calendar" => Icons.Material.Filled.CalendarMonth,
            "Warning" => Icons.Material.Filled.Warning,
            "Folder" => Icons.Material.Filled.Folder,
            "Gift" => Icons.Material.Filled.CardGiftcard,
            "Template" => Icons.Material.Filled.ContentCopy,
            _ => Icons.Material.Filled.Circle
        };
    }

    private Color GetLicenseColor()
    {
        var license = LicenseService.GetCurrentLicense();
        if (license == null) return Color.Error;

        return license.Type switch
        {
            LicenseType.Trial => Color.Warning,
            LicenseType.Basic => Color.Info,
            LicenseType.Standard => Color.Success,
            LicenseType.Professional => Color.Primary,
            LicenseType.Enterprise => Color.Secondary,
            _ => Color.Default
        };
    }

    private string GetLicenseText()
    {
        var license = LicenseService.GetCurrentLicense();
        if (license == null) return "Lisanssýz";

        var remaining = LicenseService.GetRemainingDays();
        if (remaining <= 7 && remaining > 0)
        {
            return $"{license.Type.GetDisplayName()} - {remaining} gün kaldý";
        }

        return license.Type.GetDisplayName();
    }
}
