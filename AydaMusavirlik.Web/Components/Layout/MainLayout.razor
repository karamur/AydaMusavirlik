@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!AuthService.IsAuthenticated)
{
    <RedirectToLogin />
}
else
{
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                           OnClick="@(() => _drawerOpen = !_drawerOpen)" />
            <MudText Typo="Typo.h5" Class="ml-3">AYDA Musavirlik</MudText>
            <MudSpacer />
            
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mr-4">
                Enterprise
            </MudChip>
            
            <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                <MudMenuItem>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.subtitle1">@AuthService.CurrentUser?.FullName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@GetRoleText()</MudText>
                    </div>
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Href="/profil" Icon="@Icons.Material.Filled.AccountCircle">Profil</MudMenuItem>
                @if (AuthService.IsAdmin)
                {
                    <MudMenuItem Href="/kullanicilar" Icon="@Icons.Material.Filled.People">Kullanici Yonetimi</MudMenuItem>
                }
                <MudDivider />
                <MudMenuItem OnClick="HandleLogout" Icon="@Icons.Material.Filled.Logout">Cikis Yap</MudMenuItem>
            </MudMenu>
        </MudAppBar>
        
        <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini" 
                   OpenMiniOnHover="true" ClipMode="DrawerClipMode.Always">
            <MudDrawerHeader>
                <MudText Typo="Typo.h6">Menu</MudText>
            </MudDrawerHeader>
            <MudNavMenu>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
                    Ana Sayfa
                </MudNavLink>
                
                <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">
                    Dashboard
                </MudNavLink>
                
                <MudNavGroup Title="Muhasebe" Icon="@Icons.Material.Filled.Calculate" Expanded="false">
                    <MudNavLink Href="/muhasebe/hesap-plani" Icon="@Icons.Material.Filled.AccountTree">Hesap Plani</MudNavLink>
                    <MudNavLink Href="/muhasebe/fisler" Icon="@Icons.Material.Filled.Receipt">Fisler</MudNavLink>
                    <MudNavLink Href="/muhasebe/yevmiye" Icon="@Icons.Material.Filled.ListAlt">Yevmiye</MudNavLink>
                    <MudNavLink Href="/muhasebe/mizan" Icon="@Icons.Material.Filled.TableChart">Mizan</MudNavLink>
                </MudNavGroup>
                
                <MudNavGroup Title="Bordro & IK" Icon="@Icons.Material.Filled.People" Expanded="false">
                    <MudNavLink Href="/bordro" Icon="@Icons.Material.Filled.Payment">Bordro</MudNavLink>
                    <MudNavLink Href="/puantaj" Icon="@Icons.Material.Filled.AccessTime">Puantaj</MudNavLink>
                    <MudNavLink Href="/izin-yonetimi" Icon="@Icons.Material.Filled.EventAvailable">Izin Yonetimi</MudNavLink>
                </MudNavGroup>
                
                <MudNavLink Href="/veri-analiz" Icon="@Icons.Material.Filled.Insights">
                    Veri Analiz
                </MudNavLink>
                
                <MudNavLink Href="/arge" Icon="@Icons.Material.Filled.Science">
                    Ar-Ge Projeleri
                </MudNavLink>
                
                <MudNavLink Href="/raporlar" Icon="@Icons.Material.Filled.Assessment">
                    Raporlar
                </MudNavLink>
                
                <MudNavLink Href="/bildirimler" Icon="@Icons.Material.Filled.Notifications">
                    Bildirimler
                </MudNavLink>
                
                <MudNavLink Href="/randevular" Icon="@Icons.Material.Filled.CalendarMonth">
                    Randevu & Takvim
                </MudNavLink>
                
                <MudNavGroup Title="Firmalar" Icon="@Icons.Material.Filled.Business" Expanded="false">
                    <MudNavLink Href="/firmalar" Icon="@Icons.Material.Filled.List">Firma Listesi</MudNavLink>
                    <MudNavLink Href="/firmalar/yeni" Icon="@Icons.Material.Filled.Add">Yeni Firma</MudNavLink>
                </MudNavGroup>
                
                <MudDivider Class="my-2" />
                
                @if (AuthService.IsAdmin)
                {
                    <MudNavLink Href="/kullanicilar" Icon="@Icons.Material.Filled.People">
                        Kullanici Yonetimi
                    </MudNavLink>
                    
                    <MudNavGroup Title="Ayarlar" Icon="@Icons.Material.Filled.Settings" Expanded="false">
                        <MudNavLink Href="/ayarlar/veritabani" Icon="@Icons.Material.Filled.Storage">Veritabani</MudNavLink>
                        <MudNavLink Href="/ayarlar/genel" Icon="@Icons.Material.Filled.Tune">Genel Ayarlar</MudNavLink>
                    </MudNavGroup>
                }
                
            </MudNavMenu>
        </MudDrawer>
        
        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#424242",
            AppbarBackground = "#1976D2"
        }
    };

    private void HandleLogout()
    {
        AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    private string GetRoleText()
    {
        return AuthService.CurrentUser?.Role switch
        {
            UserRole.Admin => "Sistem Yöneticisi",
            UserRole.Manager => "Yönetici",
            UserRole.Accountant => "Muhasebeci",
            UserRole.Auditor => "Denetçi",
            _ => "Kullanıcı"
        };
    }
}
