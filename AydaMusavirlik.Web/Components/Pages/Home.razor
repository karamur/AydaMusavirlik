@page "/"
@inject AuthService AuthService
@inject CompanyService CompanyService
@inject AccountingService AccountingService

<PageTitle>Ana Sayfa - AYDA Müşavirlik</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
    Hoş Geldiniz, @AuthService.CurrentUser?.FirstName!
</MudText>

<MudGrid>
    @* Özet Kartları *@
    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Toplam Firma</MudText>
                        <MudText Typo="Typo.h4">@_companyCount</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Primary" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Muhasebe Kayıtları</MudText>
                        <MudText Typo="Typo.h4">@_summary.TotalRecords</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Color="Color.Success" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Onay Bekleyen</MudText>
                        <MudText Typo="Typo.h4">@_summary.DraftRecords</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Large" Color="Color.Warning" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">İşlenen</MudText>
                        <MudText Typo="Typo.h4">@_summary.PostedRecords</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Info" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Hızlı İşlemler *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Hızlı İşlemler</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/firmalar/yeni">
                        Yeni Firma
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Receipt" Href="/muhasebe/fisler">
                        Yeni Fiş
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.AccountTree" Href="/muhasebe/hesap-plani">
                        Hesap Planı
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Assessment" Href="/raporlar">
                        Raporlar
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Firmalar *@
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Son Firmalar</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/firmalar">Tümünü Gör</MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudList T="Company" Dense="true">
                    @foreach (var company in _companies.Take(5))
                    {
                        <MudListItem Icon="@Icons.Material.Filled.Business">
                            <div class="d-flex justify-space-between align-center" style="width: 100%;">
                                <div>
                                    <MudText Typo="Typo.body1">@company.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@company.TaxNumber</MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@company.CompanyType</MudChip>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Modüller *@
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Modüller</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Elevation="2" Class="pa-4 text-center" Style="cursor: pointer;" @onclick='() => Navigate("/muhasebe/fisler")'>
                            <MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Muhasebe</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Aktif</MudChip>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Elevation="2" Class="pa-4 text-center" Style="cursor: pointer;">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Bordro</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Yakında</MudChip>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Elevation="2" Class="pa-4 text-center" Style="cursor: pointer;">
                            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Denetim</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Yakında</MudChip>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Elevation="2" Class="pa-4 text-center" Style="cursor: pointer;">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Finansal Analiz</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Yakında</MudChip>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Elevation="2" Class="pa-4 text-center" Style="cursor: pointer;">
                            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">AR-GE</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Yakında</MudChip>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Elevation="2" Class="pa-4 text-center" Style="cursor: pointer;">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Şirket Kuruluşu</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Yakında</MudChip>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private List<Company> _companies = new();
    private int _companyCount;
    private AccountingSummary _summary = new();

    [Inject]
    private NavigationManager NavigationManager { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _companies = await CompanyService.GetAllAsync();
        _companyCount = _companies.Count;
        _summary = await AccountingService.GetSummaryAsync(1);
    }

    private void Navigate(string url)
    {
        NavigationManager.NavigateTo(url);
    }
}
