@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudCard Elevation="4" Class="pa-4" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex flex-column align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.h4" Color="Color.Primary">AYDA Müţavirlik</MudText>
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Profesyonel Mali Müţavirlik Sistemi</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudTextField @bind-Value="Username"
                          Label="Kullanýcý Adý"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@IsLoading" />

            <MudTextField @bind-Value="Password"
                          Label="Ţifre"
                          Variant="Variant.Outlined"
                          InputType="@PasswordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@PasswordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@IsLoading" />

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                    @ErrorMessage
                </MudAlert>
            }
            
            @if (LoginSuccess)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true">
                    Giriţ baţarýlý! Yönlendiriliyorsunuz...
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="@(string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password) || IsLoading)">
                @if (IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Giriţ yapýlýyor...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                    <span>Giriţ Yap</span>
                }
            </MudButton>
        </MudCardContent>

        <MudCardActions Class="d-flex flex-column pa-4">
            <MudDivider Class="mb-4" />
            
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mb-2">
                <strong>Test Kullanýcýlarý:</strong>
            </MudText>
            
            <MudStack Row="true" Justify="Justify.Center" Spacing="2" Class="mb-3">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => SetCredentials("admin", "admin"))">
                    Admin
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                           OnClick="@(() => SetCredentials("muhasebe", "muhasebe123"))">
                    Muhasebeci
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                           OnClick="@(() => SetCredentials("yonetici", "yonetici123"))">
                    Yönetici
                </MudButton>
            </MudStack>

            <MudSimpleTable Dense="true" Hover="true" Style="font-size: 0.75rem;">
                <thead>
                    <tr>
                        <th>Kullanýcý</th>
                        <th>Ţifre</th>
                        <th>Yetki</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>admin</code></td>
                        <td><code>admin</code></td>
                        <td>Tam Eriţim</td>
                    </tr>
                    <tr>
                        <td><code>muhasebe</code></td>
                        <td><code>muhasebe123</code></td>
                        <td>Muhasebe</td>
                    </tr>
                    <tr>
                        <td><code>yonetici</code></td>
                        <td><code>yonetici123</code></td>
                        <td>Raporlar</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string Username { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool LoginSuccess { get; set; }
    
    private bool PasswordVisible { get; set; }
    private InputType PasswordInputType => PasswordVisible ? InputType.Text : InputType.Password;
    private string PasswordIcon => PasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void TogglePasswordVisibility()
    {
        PasswordVisible = !PasswordVisible;
    }

    private void SetCredentials(string username, string password)
    {
        Username = username;
        Password = password;
        ErrorMessage = null;
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Kullanýcý adý ve ţifre gerekli";
            return;
        }

        IsLoading = true;
        ErrorMessage = null;
        LoginSuccess = false;

        try
        {
            await Task.Delay(200);
            
            var result = await AuthService.LoginAsync(Username, Password);

            if (result.Success)
            {
                LoginSuccess = true;
                Snackbar.Add(result.Message ?? "Giriţ baţarýlý!", Severity.Success);
                await Task.Delay(500);
                Navigation.NavigateTo("/");
            }
            else
            {
                ErrorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Giriţ hatasý: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
