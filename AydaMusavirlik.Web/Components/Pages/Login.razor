@page "/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudCard Elevation="4" Class="pa-4" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex flex-column align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.h4" Color="Color.Primary">AYDA M³■avirlik</MudText>
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Profesyonel Mali M³■avirlik Sistemi</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudTextField @bind-Value="_username"
                          Label="Kullan²c² Ad²"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@_isLoading" />

            <MudTextField @bind-Value="_password"
                          Label="Ìifre"
                          Variant="Variant.Outlined"
                          InputType="@_passwordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@_isLoading" />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                    @_errorMessage
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="@(string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password) || _isLoading)">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Giri■ yap²l²yor...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                    <span>Giri■ Yap</span>
                }
            </MudButton>
        </MudCardContent>

        <MudCardActions Class="d-flex flex-column pa-4">
            <MudDivider Class="mb-4" />
            
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mb-2">
                <strong>Test Kullan²c²lar² (t²klay²n):</strong>
            </MudText>
            
            <MudButtonGroup OverrideStyles="false" Class="d-flex justify-center flex-wrap gap-2 mb-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick='() => FillCredentials("admin", "admin")'>
                    Admin
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                           OnClick='() => FillCredentials("muhasebe", "muhasebe123")'>
                    Muhasebeci
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                           OnClick='() => FillCredentials("yonetici", "yonetici123")'>
                    Y÷netici
                </MudButton>
            </MudButtonGroup>

            <MudSimpleTable Dense="true" Hover="true" Class="mb-2" Style="font-size: 0.8rem;">
                <thead>
                    <tr>
                        <th>Kullan²c²</th>
                        <th>Ìifre</th>
                        <th>Yetki</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>admin</code></td>
                        <td><code>admin</code></td>
                        <td>Tam Eri■im</td>
                    </tr>
                    <tr>
                        <td><code>muhasebe</code></td>
                        <td><code>muhasebe123</code></td>
                        <td>Muhasebe</td>
                    </tr>
                    <tr>
                        <td><code>yonetici</code></td>
                        <td><code>yonetici123</code></td>
                        <td>Raporlar</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private bool _isLoading;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string? _errorMessage;

    private bool _passwordVisible;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void TogglePasswordVisibility()
    {
        _passwordVisible = !_passwordVisible;
        _passwordInputType = _passwordVisible ? InputType.Text : InputType.Password;
        _passwordIcon = _passwordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }

    private void FillCredentials(string username, string password)
    {
        _username = username;
        _password = password;
        _errorMessage = null;
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "Kullan²c² ad² ve ■ifre gerekli";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.LoginAsync(_username, _password);

            if (result.Success)
            {
                Snackbar.Add(result.Message ?? "Giri■ ba■ar²l²!", Severity.Success);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _errorMessage = result.ErrorMessage;
            }
        }
        catch
        {
            _errorMessage = "Beklenmeyen bir hata olu■tu";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
