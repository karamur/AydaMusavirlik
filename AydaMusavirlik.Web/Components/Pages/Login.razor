@page "/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudCard Elevation="4" Class="pa-4" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex flex-column align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.h4" Color="Color.Primary">AYDA Musavirlik</MudText>
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Profesyonel Mali Musavirlik Sistemi</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudTextField @bind-Value="Username"
                          Label="Kullanici Adi"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@IsLoading" />

            <MudTextField @bind-Value="Password"
                          Label="Sifre"
                          Variant="Variant.Outlined"
                          InputType="@PasswordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@PasswordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@IsLoading" />

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                    @ErrorMessage
                </MudAlert>
            }
            
            @if (LoginSuccess)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true">
                    Giris basarili! Yonlendiriliyorsunuz...
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="@(string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password) || IsLoading)">
                @if (IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Giris yapiliyor...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                    <span>Giris Yap</span>
                }
            </MudButton>
        </MudCardContent>

        <MudCardActions Class="d-flex flex-column pa-4">
            <MudDivider Class="mb-4" />
            
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mb-2">
                <strong>Test Kullanicilari:</strong>
            </MudText>
            
            <MudStack Row="true" Justify="Justify.Center" Spacing="2" Class="mb-3">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                           OnClick="() => SetCredentialsAdmin()">
                    Admin
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                           OnClick="() => SetCredentialsMuhasebe()">
                    Muhasebeci
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                           OnClick="() => SetCredentialsYonetici()">
                    Yonetici
                </MudButton>
            </MudStack>

            <MudSimpleTable Dense="true" Hover="true" Style="font-size: 0.75rem;">
                <thead>
                    <tr>
                        <th>Kullanici</th>
                        <th>Sifre</th>
                        <th>Yetki</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>admin</code></td>
                        <td><code>admin</code></td>
                        <td>Tam Erisim</td>
                    </tr>
                    <tr>
                        <td><code>muhasebe</code></td>
                        <td><code>muhasebe123</code></td>
                        <td>Muhasebe</td>
                    </tr>
                    <tr>
                        <td><code>yonetici</code></td>
                        <td><code>yonetici123</code></td>
                        <td>Raporlar</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string Username { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool LoginSuccess { get; set; }

    private bool PasswordVisible { get; set; }
    private InputType PasswordInputType => PasswordVisible ? InputType.Text : InputType.Password;
    private string PasswordIcon => PasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();

        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private void TogglePasswordVisibility()
    {
        PasswordVisible = !PasswordVisible;
    }

    private void SetCredentialsAdmin()
    {
        Username = "admin";
        Password = "admin";
        ErrorMessage = null;
    }

    private void SetCredentialsMuhasebe()
    {
        Username = "muhasebe";
        Password = "muhasebe123";
        ErrorMessage = null;
    }

    private void SetCredentialsYonetici()
    {
        Username = "yonetici";
        Password = "yonetici123";
        ErrorMessage = null;
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Kullanici adi ve sifre gerekli";
            return;
        }

        IsLoading = true;
        ErrorMessage = null;
        LoginSuccess = false;
        StateHasChanged();

        try
        {
            var result = await AuthService.LoginAsync(Username, Password);

            if (result.Success)
            {
                LoginSuccess = true;
                Snackbar.Add($"Hosgeldiniz, {result.User?.FullName ?? Username}!", Severity.Success);
                StateHasChanged();
                await Task.Delay(300);
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                ErrorMessage = result.ErrorMessage ?? "Giris basarisiz";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Giris hatasi: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
